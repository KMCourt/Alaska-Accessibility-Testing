# ===========================================
# ENVIRONMENT VARIABLES — CPCBA Accessibility Tests
# ===========================================
# Copy this file to .env and fill in your values.
# The .env file is gitignored and must never be committed.
#
#   cp .env.example .env
#
# Contact the QA team lead for the real values.
# ===========================================

# -------------------------------------------
# Testmail — used to receive OTP emails during automated tests
# Get your credentials at: https://testmail.app
# -------------------------------------------
TESTMAIL_API_KEY=your-testmail-api-key-here
TESTMAIL_NAMESPACE=your-namespace-here
TESTMAIL_TAG=test

# -------------------------------------------
# Microsoft Teams webhook — posts a summary to Teams when tests finish
# Create via: Teams channel → ... → Connectors → Incoming Webhook
# Leave blank to disable Teams notifications
# -------------------------------------------
TEAMS_WEBHOOK_URL=your-teams-webhook-url-here
